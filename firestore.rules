rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isOwner(userId);
    }

    match /nickname_index/{nickname} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /leaderboard/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /friend_requests/{requestId} {
      allow read: if isAuthenticated() && 
        (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.receiverId == request.auth.uid;
      allow delete: if isAuthenticated() && 
        (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
    }

    match /friends/{userId}/{friendId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }

    match /skins/{skinId} {
      allow read: if isAuthenticated();
      allow write: if false; 
    }

    match /user_skins/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }

    // Phase 2: Party Rooms
    match /party_rooms/{roomId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.hostId == request.auth.uid;
      // Host can update anything, guest can update to join
      allow update: if isAuthenticated() && (
        resource.data.hostId == request.auth.uid || 
        request.resource.data.guestId == request.auth.uid
      );
      allow delete: if isAuthenticated() && resource.data.hostId == request.auth.uid;
    }

    // Phase 2: Notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.receiverId == request.auth.uid;
      allow create: if isAuthenticated(); // Anyone can trigger a notification (like friend invite)
      allow update, delete: if isAuthenticated() && resource.data.receiverId == request.auth.uid;
    }
  }
}
